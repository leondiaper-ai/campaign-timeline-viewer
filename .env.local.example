# Google Sheets API credentials
# See README.md for setup instructions
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Registry spreadsheet ID (the central hub that lists all campaign sheets)
REGISTRY_SPREADSHEET_ID=your_registry_spreadsheet_id_here

# Legacy: single spreadsheet mode
# GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Set to "true" to use mock data instead of Google Sheets
USE_MOCK_DATA=true

# Airtable configuration (optional — enables Airtable as data source)
# When both are set, data.ts will fetch from Airtable instead of Google Sheets.
# Get a Personal Access Token from https://airtable.com/create/tokens
AIRTABLE_BASE_ID=app8JJy12pMmD26Nt
AIRTABLE_API_KEY=pat_your_token_here
